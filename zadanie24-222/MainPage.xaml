<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zadanie24_222.MainPage">

    <ScrollView>
        <VerticalStackLayout
          Padding="30,0"
          Spacing="25">
            <Editor
             x:Name="EditorWpis"
              />

            <Button
               x:Name="DodajWpisButton"
              Text="Dodaj wpis"
                Clicked="DodawanieWpisu"
              />
            <ScrollView>
                <Label
                  x:Name="Dziennik"
                  />

            </ScrollView>


            <Button
                x:Name="Czysc"
              Text="Wyczysc dziennik" 
                Clicked="WyczyscDziennik"
              />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
