<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zadanie24_4.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Editor
                x:Name="EditorNotatka"
                />

            <Button
                Text="Eksportuj"
                x:Name="EksportujButton"
                Clicked="EksportClicked"
                />
                
            <Button
                Text="Importuj"
                x:Name="ImportujButton"
                Clicked="ImportClicked"
                />

            
            <Label
                x:Name="Obsluga"
                />
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
